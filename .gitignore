# KiCad autosave / lock / backup
_autosave-*
*-backups/
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.kicad_prl
*.lck
*~

# Pre-edit backups
*.pre_*_backup

# Build / output (gerbers regenerable; track only README + BOM + pos)
*.drl
*.gbr
*.gbrjob
fab/gerbers/

# DRC/ERC reports
*-drc.rpt
*-erc.rpt

# Renders (committed periodically with `git add -f renders/assembly.png`)
renders/

# Heavy regenerable 3D assets
fab/3d/*.step
fab/3d/*.glb

# KiCad Local History (auto snapshots; each is a nested git repo)
.history/

# Claude Code session state
.claude/

# Python
__pycache__/
*.pyc

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
routing_phase/escape_plan.json
routing_phase/bus_plan.json
